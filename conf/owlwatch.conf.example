# owlwatch.conf — owlwatch 配置文件
# 复制为 owlwatch.conf 并按需修改：
#   cp owlwatch.conf.example owlwatch.conf
#
# 优先级：环境变量（OW_ 前缀） > 本文件 > 内置默认值
# 例如：export OW_CPU_WARN_THRESHOLD=90

# ─── 告警阈值 ───

# CPU 使用率告警阈值（%）
CPU_WARN_THRESHOLD=70

# 内存使用率告警阈值（%）
MEM_WARN_THRESHOLD=80

# 磁盘使用率告警阈值（%）
DISK_WARN_THRESHOLD=85

# ─── 孤儿进程检测 ───

# 孤儿进程 CPU 阈值（%），低于此值不计为孤儿
ORPHAN_CPU_THRESHOLD=50

# 孤儿进程最小运行时间（分钟），短于此不计为孤儿
ORPHAN_MIN_RUNTIME=30

# 要检测的孤儿进程名模式（空格分隔）
ORPHAN_PATTERNS="codex claude-mem-codex-watcher"

# 永不杀掉的进程名（空格分隔），包含这些关键字的进程会被保护
PROTECT_NAMES="kernel_task WindowServer loginwindow launchd syslogd"

# ─── Daemon 配置 ───

# Daemon 检查间隔（秒），默认 1800 = 30 分钟
DAEMON_INTERVAL=1800

# ─── 日志 ───

# 日志目录
LOG_DIR="$HOME/.claude/logs"

# 日志文件最大大小（字节），超过自动轮转
LOG_MAX_SIZE=1048576
